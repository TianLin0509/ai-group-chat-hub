{
  "name": "ai-group-chat-hub",
  "version": "1.1.0",
  "description": "多模型 AI 群聊 Hub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "test:syntax": "node scripts/check-syntax.js",
    "dist": "electron-builder --win"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "node-pty": "^1.0.0",
    "prismjs": "^1.30.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.ai-group-chat-hub",
    "productName": "AI 群聊 Hub",
    "win": {
      "target": "nsis",
      "icon": "claude-wx.ico",
      "signAndEditExecutable": false,
      "artifactName": "AIGroupChatHub-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "claude-wx.ico",
      "uninstallerIcon": "claude-wx.ico",
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "main/**/*",
      "core/**/*",
      "renderer/**/*",
      "scripts/**/*",
      "!scripts/firewall-whitelist-electron.ps1",
      "!scripts/__pycache__/**",
      "!scripts/check-syntax.js",
      "claude-wx.ico",
      "package.json"
    ],
    "asarUnpack": [
      "core/claude-fast-settings.json",
      "core/claude-subscription-fast-settings.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*",
          "!firewall-whitelist-electron.ps1"
        ]
      }
    ]
  }
}
